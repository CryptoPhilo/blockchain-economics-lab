# ============================================
# Blockchain Economics Lab - Environment Config
# ============================================
# Copy this file to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Crypto Receiving Addresses ---
BTC_RECEIVING_ADDRESS=bc1q...
ETH_RECEIVING_ADDRESS=0x...
USDT_RECEIVING_ADDRESS=0x...
USDC_RECEIVING_ADDRESS=0x...

# --- Ethereum RPC ---
ETH_RPC_URL=https://eth.llamarpc.com

# --- App ---
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://bcelab.xyz

# --- Email ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_WEBHOOK_SECRET=your_svix_webhook_secret
EMAIL_FROM=BCE Lab <research@bcelab.xyz>

# --- Newsletter & Cron ---
NEWSLETTER_API_SECRET=your_strong_random_secret_min_32_bytes
CRON_API_SECRET=your_strong_random_secret_min_32_bytes

# --- Google Drive ---
GDRIVE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
GDRIVE_ROOT_FOLDER_ID=your_gdrive_folder_id
GDRIVE_DELEGATE_EMAIL=your_delegate@example.com

# --- Pipeline ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# --- Market Data ---
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
BETA_SIGNAL_INTERNAL_API_SECRET=your-internal-beta-signal-secret
# Local-only by default. Set to true only when a private network deployment
# must expose /api/internal/beta-signals intentionally.
BETA_SIGNAL_INTERNAL_API_ALLOW_PUBLIC=false
