# ============================================
# Blockchain Economics Lab - Environment Config
# ============================================
# Copy this file to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Crypto Receiving Addresses ---
BTC_RECEIVING_ADDRESS=bc1q...
ETH_RECEIVING_ADDRESS=0x...
USDT_RECEIVING_ADDRESS=0x...
USDC_RECEIVING_ADDRESS=0x...

# --- Ethereum RPC ---
ETH_RPC_URL=https://eth.llamarpc.com

# --- App ---
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://bcelab.xyz

# --- Email ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_WEBHOOK_SECRET=your_svix_webhook_secret
EMAIL_FROM=BCE Lab <research@bcelab.xyz>

# --- Newsletter & Cron ---
NEWSLETTER_API_SECRET=your_strong_random_secret_min_32_bytes
CRON_API_SECRET=your_strong_random_secret_min_32_bytes

# --- Google Drive ---
GDRIVE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
GDRIVE_ROOT_FOLDER_ID=your_gdrive_folder_id
GDRIVE_DELEGATE_EMAIL=your_delegate@example.com

# --- Pipeline ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# --- Paperclip Pipeline Telemetry (optional) ---
# watch_slides.py publishes best-effort runs/events when these are configured.
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_API_KEY=your_paperclip_api_key
PAPERCLIP_COMPANY_ID=your_paperclip_company_id
PAPERCLIP_ECON_PIPELINE_ID=your_econ_pipeline_id
PAPERCLIP_MAT_PIPELINE_ID=your_mat_pipeline_id
PAPERCLIP_FOR_PIPELINE_ID=your_for_pipeline_id

# --- X Manual Posting ---
# Dry-run and approval queue generation do not require these values.
# Real posting requires --post --confirm <slug> and the four OAuth 1.0a user-context values below.
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
# Optional for read-only diagnostics; not sufficient for posting by itself.
X_BEARER_TOKEN=your_x_bearer_token

# --- Market Data ---
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
# Optional alias used by newer CMC scripts. When both are set, CMC_API_KEY wins.
# Leave the sudden movers card-anchor bridge disabled unless a production owner
# explicitly signs off on first-run monitoring.
CMC_API_KEY=
ENABLE_SUDDEN_MOVERS_CARD_ANCHOR=false
SUDDEN_MOVERS_CARD_ANCHOR_STATE=scripts/pipeline/output/sudden_movers_card_anchor_state.json
SUDDEN_MOVERS_CARD_ANCHOR_OUTPUT=scripts/pipeline/output/sudden_movers_card_anchors.jsonl
BETA_SIGNAL_INTERNAL_API_SECRET=your-internal-beta-signal-secret
# Local-only by default. Set to true only when a private network deployment
# must expose /api/internal/beta-signals intentionally.
BETA_SIGNAL_INTERNAL_API_ALLOW_PUBLIC=false
