{
  "version": 1,
  "company": "BCELab",
  "principle": "Paperclip owns the operating definition; this repository owns the executable manifest; CI verifies the mapping before code can be deployed or remote jobs can run.",
  "remoteFirst": true,
  "localExecutionPolicy": {
    "allowedPurposes": ["dry_run", "development", "incident_reproduction"],
    "productionWritesAllowed": false,
    "requiredEvidence": "Local pipeline execution must be linked to a Paperclip issue and rerun remotely before production approval."
  },
  "pipelines": [
    {
      "key": "econ-report-publishing",
      "paperclipName": "ECON Report Publishing",
      "statePage": "knowledge/pipelines/econ.md",
      "owner": "CRO",
      "status": "active",
      "cadence": {
        "kind": "scheduled",
        "workflow": ".github/workflows/slide-pipeline-cron.yml",
        "cron": "*/5 * * * *",
        "runtimeGate": "Supabase pipeline_schedules row where pipeline_name=slide-pipeline",
        "expectedIntervalMinutes": 30
      },
      "nodes": [
        {
          "key": "source_collection",
          "paperclipLabel": "Slide PDF intake",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/slide-pipeline-cron.yml",
            "entrypoint": "scripts/pipeline/watch_slides.py",
            "commandContains": "python3 watch_slides.py",
            "args": ["--type", "econ", "--drive-root-scope", "active"],
            "localAllowed": ["dry_run", "development"]
          }
        },
        {
          "key": "research_synthesis",
          "paperclipLabel": "Analysis source confirmation",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/slide-pipeline-cron.yml",
            "entrypoint": "scripts/pipeline/watch_slides.py",
            "commandContains": "python3 watch_slides.py",
            "localAllowed": ["dry_run", "development"]
          }
        },
        {
          "key": "draft_report",
          "paperclipLabel": "Summary and marketing extraction",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/slide-pipeline-cron.yml",
            "entrypoint": "scripts/pipeline/marketing_content_pipeline.py",
            "invokedBy": "scripts/pipeline/watch_slides.py",
            "requiredImport": "from marketing_content_pipeline import build_project_report_patch_from_drive_source",
            "commandContains": "python3 watch_slides.py",
            "localAllowed": ["dry_run", "development"]
          }
        },
        {
          "key": "summary_marketing_localization",
          "paperclipLabel": "7-language summary and marketing localization",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/slide-pipeline-cron.yml",
            "entrypoint": "scripts/pipeline/marketing_content_pipeline.py",
            "invokedBy": "scripts/pipeline/watch_slides.py",
            "requiredImport": "from marketing_content_pipeline import build_project_report_patch_from_drive_source",
            "commandContains": "python3 watch_slides.py",
            "localAllowed": ["dry_run", "development"]
          }
        },
        {
          "key": "editorial_review",
          "paperclipLabel": "Publication review",
          "approvalGate": {
            "system": "Paperclip",
            "required": true,
            "owner": "COO"
          }
        },
        {
          "key": "website_publish",
          "paperclipLabel": "Website publishing",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/slide-pipeline-cron.yml",
            "entrypoint": "scripts/pipeline/watch_slides.py",
            "commandContains": "python3 watch_slides.py",
            "localAllowed": ["dry_run", "development"]
          }
        },
        {
          "key": "post_publish_monitoring",
          "paperclipLabel": "Post-publish monitoring",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/pipeline-daily-report.yml",
            "entrypoint": "scripts/pipeline/daily_pipeline_report.py",
            "commandContains": "daily_pipeline_report.py",
            "localAllowed": ["development"]
          }
        }
      ]
    },
    {
      "key": "mat-report-publishing",
      "paperclipName": "MAT Report Publishing",
      "statePage": "knowledge/pipelines/mat.md",
      "extends": "econ-report-publishing",
      "owner": "CRO",
      "status": "active",
      "reportType": "mat"
    },
    {
      "key": "for-report-publishing",
      "paperclipName": "FOR Report Publishing",
      "statePage": "knowledge/pipelines/for.md",
      "extends": "econ-report-publishing",
      "owner": "CRO",
      "status": "active",
      "reportType": "for"
    },
    {
      "key": "analysis-md-summary-candidate",
      "paperclipName": "Drive Analysis Markdown Summary Candidate",
      "statePage": "knowledge/pipelines/analysis-md-summary-candidate.md",
      "owner": "DataPlatformEngineer",
      "status": "candidate",
      "activation": "Default off. Candidate/dry-run only until remote production-write approval.",
      "inputs": {
        "active": "Google Drive analysis2/{ECON,MAT,FOR} Markdown or an explicit local --source-path for development dry-runs",
        "legacy": "Google Drive analysis/{ECON,MAT,FOR} Markdown when --drive-root-scope legacy or all is explicitly selected"
      },
      "outputs": {
        "artifact": "scripts/pipeline/output/analysis_md_summary_candidate_${type}_${slug}.json",
        "candidateJobs": "Supabase report_summary_jobs rows keyed by idempotency_key when dry_run=false; source_identity is retained as provenance",
        "authorityGate": "Default-off promotion through report_summary_jobs authority_state/authority_mode and report_summary_promotion_locks",
        "telemetry": "Supabase pipeline_runs, pipeline_node_runs, and pipeline_events rows under pipeline_name=analysis-md-summary-candidate"
      },
      "boundaries": {
        "productionPublish": "Does not write project_reports or publish website-visible content.",
        "idempotency": "reportCode + reportSlug + locale + driveFileId + revision/hash + promptVersion + schemaVersion.",
        "approval": "Promotion from report_summary_jobs to project_reports requires a separate remote approval.",
        "authorityModes": "legacy_script and llm_candidate retain legacy active summaries; llm_active may promote only validation-passed candidates through the Summary Authority Gate."
      },
      "nodes": [
        {
          "key": "analysis_md_source_scan",
          "paperclipLabel": "Drive analysis Markdown scan",
          "execution": {
            "mode": "paperclip_agent",
            "entrypoint": "scripts/pipeline/analysis_md_summary_candidate.py",
            "commandContains": "analysis_md_summary_candidate.py",
            "args": ["--type", "econ|mat|for", "--slug", "<slug>", "--drive-root-scope", "active", "--dry-run"],
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "summary_candidate_generation",
          "paperclipLabel": "LLM summary candidate generation",
          "execution": {
            "mode": "paperclip_agent",
            "entrypoint": "scripts/pipeline/analysis_md_summary_candidate.py",
            "commandContains": "analysis_md_summary_candidate.py",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "candidate_validation",
          "paperclipLabel": "Schema, language, quality, and grounding validation",
          "execution": {
            "mode": "paperclip_agent",
            "entrypoint": "scripts/pipeline/analysis_md_summary_candidate.py",
            "commandContains": "analysis_md_summary_candidate.py",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "candidate_job_upsert",
          "paperclipLabel": "Default-off report summary job upsert",
          "execution": {
            "mode": "paperclip_agent",
            "entrypoint": "scripts/pipeline/analysis_md_summary_candidate.py",
            "commandContains": "analysis_md_summary_candidate.py",
            "localAllowed": ["dry_run", "development"]
          }
        },
        {
          "key": "summary_authority_gate",
          "paperclipLabel": "Default-off candidate promotion authority gate",
          "execution": {
            "mode": "paperclip_agent",
            "entrypoint": "scripts/pipeline/summary_authority_gate.py",
            "commandContains": "summary_authority_gate.py",
            "args": ["--job-id", "<uuid>", "--authority-mode", "legacy_script|llm_candidate|llm_active"],
            "localAllowed": ["dry_run", "development"]
          },
          "approvalGate": {
            "system": "Paperclip",
            "required": true,
            "owner": "COO"
          }
        }
      ]
    },
    {
      "key": "forensic-rapid-change-scan",
      "paperclipName": "Forensic Rapid Change Scan",
      "statePage": "knowledge/pipelines/forensic-rapid-change-scan.md",
      "owner": "CRO",
      "status": "active",
      "cadence": {
        "kind": "manual_dispatch",
        "workflow": ".github/workflows/forensic-rapid-change-scan.yml",
        "defaultDryRun": true
      },
      "inputs": {
        "marketData": "CoinMarketCap listings/latest via COINMARKETCAP_API_KEY",
        "defaults": {
          "top": 500,
          "thresholdSource": "scripts/pipeline/config.py::get_forensic_scan_deviation_threshold",
          "enableCardAnchor": false,
          "dryRun": true
        }
      },
      "outputs": {
        "artifact": "scripts/pipeline/output/sudden_movers_card_anchor_${GITHUB_RUN_ID}.json",
        "telemetry": "Supabase pipeline_runs, pipeline_node_runs, and pipeline_events rows under pipeline_name=forensic-rapid-change-scan",
        "stateWhenWriteEnabled": "scripts/pipeline/output/sudden_movers_card_anchor_state.json",
        "anchorsWhenWriteEnabled": "scripts/pipeline/output/sudden_movers_card_anchors.jsonl"
      },
      "boundaries": {
        "currentRuntime": "scripts/pipeline/sudden_movers_card_anchor.py",
        "candidateScanner": "scripts/pipeline/candidates/sudden_movers_scanner.py",
        "legacyRegistrationContract": "_legacy/pipeline/scan_forensic.py",
        "activation": "Default off; anchor writes require workflow input enable_card_anchor=true and dry_run=false."
      },
      "nodes": [
        {
          "key": "candidate_scan",
          "paperclipLabel": "Sudden mover candidate scan",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/forensic-rapid-change-scan.yml",
            "entrypoint": "scripts/pipeline/candidates/sudden_movers_scanner.py",
            "invokedBy": "scripts/pipeline/sudden_movers_card_anchor.py",
            "requiredImport": "run_candidate_scan",
            "commandContains": "sudden_movers_card_anchor.py",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "card_anchor_bridge",
          "paperclipLabel": "Default-off FOR card anchor bridge",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/forensic-rapid-change-scan.yml",
            "entrypoint": "scripts/pipeline/sudden_movers_card_anchor.py",
            "commandContains": "sudden_movers_card_anchor.py",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "scan_result_artifact",
          "paperclipLabel": "Rapid-change scan evidence artifact",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/forensic-rapid-change-scan.yml",
            "commandContains": "forensic-rapid-change-scan-",
            "localAllowed": ["development"]
          }
        }
      ]
    },
    {
      "key": "x-promo-manual-post",
      "paperclipName": "X Promo Manual Post",
      "statePage": "knowledge/pipelines/x-promo.md",
      "owner": "CMO",
      "status": "active",
      "cadence": {
        "kind": "manual_dispatch",
        "workflow": ".github/workflows/x-promo-manual-post.yml",
        "defaultDryRun": true
      },
      "inputs": {
        "source": "Production Supabase project_reports rows with marketing_content_by_lang or card-summary fallback",
        "dispatch": {
          "confirmKey": "workflow_dispatch input confirm_key; exact approved duplicate_key",
          "confirmSlug": "workflow_dispatch input confirm_slug; exact report slug",
          "post": "workflow_dispatch input post; false is dry-run, true calls X API",
          "limit": "workflow_dispatch input limit; maximum production rows to inspect"
        },
        "secrets": [
          "SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL",
          "SUPABASE_SERVICE_KEY",
          "X_API_KEY",
          "X_API_SECRET",
          "X_ACCESS_TOKEN",
          "X_ACCESS_TOKEN_SECRET"
        ]
      },
      "outputs": {
        "approvalQueue": "data/x-approval-queue/x-promo-approval-${RUN_ID}.jsonl and .md",
        "approvedQueue": "data/x-approval-queue/x-promo-approved-${RUN_ID}.jsonl",
        "postLog": "data/x-post-attempts.jsonl",
        "artifact": "x-promo-manual-post-${{ github.run_id }}-${{ github.run_attempt }}"
      },
      "boundaries": {
        "postingDefault": "Dry-run unless workflow input post=true and script receives --post.",
        "approval": "Workflow approves exactly one row only when confirm_key and confirm_slug match one generated queue row.",
        "duplicateGuard": "scripts/pipeline/x_promo_pipeline.py skips rows with an existing posted result for the same duplicate_key.",
        "localPolicy": "Local execution is for dry-run, development, or incident reproduction only; live X posts use the remote workflow.",
        "secretPolicy": "Do not record X or Supabase secret values in Paperclip comments, GitHub logs, artifacts, or commits.",
        "incidentBoundary": "Real-post run 25359605164 reached POST https://api.x.com/2/tweets and failed with HTTP 403; treat as X Developer Console tier/permission/OAuth token/App environment blocker until X-side state is confirmed."
      },
      "nodes": [
        {
          "key": "production_queue_generation",
          "paperclipLabel": "Production X promo queue generation",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/x-promo-manual-post.yml",
            "entrypoint": "scripts/pipeline/x_promo_pipeline.py",
            "commandContains": "x_promo_pipeline.py",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "single_row_manual_approval",
          "paperclipLabel": "Exact single-row manual approval",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/x-promo-manual-post.yml",
            "commandContains": "Approved exactly one queue row",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "dry_run_selected_post",
          "paperclipLabel": "Selected post dry-run",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/x-promo-manual-post.yml",
            "entrypoint": "scripts/pipeline/x_promo_pipeline.py",
            "commandContains": "x_promo_pipeline.py",
            "localAllowed": ["dry_run", "development", "incident_reproduction"]
          }
        },
        {
          "key": "post_selected_item",
          "paperclipLabel": "Selected item X post",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/x-promo-manual-post.yml",
            "entrypoint": "scripts/pipeline/x_promo_pipeline.py",
            "commandContains": "x_promo_pipeline.py",
            "localAllowed": ["incident_reproduction"]
          }
        },
        {
          "key": "approval_and_post_artifacts",
          "paperclipLabel": "Approval and post evidence artifact",
          "execution": {
            "mode": "github_actions",
            "workflow": ".github/workflows/x-promo-manual-post.yml",
            "commandContains": "x-promo-manual-post-",
            "localAllowed": ["development"]
          }
        }
      ]
    },
    {
      "key": "bcelab-website-development-and-operations",
